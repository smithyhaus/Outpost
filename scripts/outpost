#!/usr/bin/env bash
# =============================================================================
# outpost — single-entry CLI for app-team daily commands.
# -----------------------------------------------------------------------------
# Wraps the half-dozen kubectl/argocd/kubeseal incantations every Outpost user
# eventually memorizes. Add to PATH:
#   ln -s "$PWD/scripts/outpost" /usr/local/bin/outpost
# Or run as `bash scripts/outpost <subcommand>`.
# =============================================================================
set -euo pipefail

# Resolve this script through any symlinks before deriving OUTPOST_HOME —
# `make install` symlinks it into PREFIX, so ${BASH_SOURCE[0]} is the symlink,
# not the repo file. Portable (macOS has no `readlink -f`).
if [[ -z "${OUTPOST_HOME:-}" ]]; then
  _outpost_self="${BASH_SOURCE[0]}"
  while [[ -L "$_outpost_self" ]]; do
    _outpost_link="$(readlink "$_outpost_self")"
    case "$_outpost_link" in
      /*) _outpost_self="$_outpost_link" ;;
      *)  _outpost_self="$(dirname "$_outpost_self")/$_outpost_link" ;;
    esac
  done
  OUTPOST_HOME="$(cd "$(dirname "$_outpost_self")/.." && pwd)"
fi
cd "$OUTPOST_HOME"

# Load .env if present — every subcommand wants ROOT_DOMAIN / dashboard creds /
# argocd admin pwd. Missing .env is fine for `help` / `version`. Tests and
# specialised callers may pre-export every variable they need and skip the
# auto-source via OUTPOST_NO_ENV=1 (so caller-set env wins over on-disk .env).
if [[ -f .env && "${OUTPOST_NO_ENV:-0}" != "1" ]]; then
  set -a; # shellcheck disable=SC1091
  source .env
  set +a
fi

# Shared libs: render_template (envsubst + strict ${VAR} residue check) and
# the onboard-primitive helpers. Both are source-only definition files.
# shellcheck source=../platform/lib/portable.sh
source "$OUTPOST_HOME/platform/lib/portable.sh"
# shellcheck source=../platform/lib/onboard-lib.sh
source "$OUTPOST_HOME/platform/lib/onboard-lib.sh"

# --- helpers -----------------------------------------------------------------
_red()    { printf '\033[31m%s\033[0m' "$*"; }
_green()  { printf '\033[32m%s\033[0m' "$*"; }
_yellow() { printf '\033[33m%s\033[0m' "$*"; }
_dim()    { printf '\033[2m%s\033[0m' "$*"; }
_die()    { echo "$(_red ERROR): $*" >&2; exit 1; }
_need()   { command -v "$1" >/dev/null 2>&1 || _die "missing tool: $1"; }
_confirm() {
  local prompt="$1" ans
  read -r -p "$prompt [y/N] " ans
  [[ "$ans" =~ ^[Yy]$ ]]
}

usage() {
  cat <<EOF
$(_green outpost) — daily CLI for the Outpost dev backend.

$(_yellow USAGE)
  outpost <subcommand> [args]

$(_yellow PLATFORM)
  status                            Compose + k8s overview (= status.sh)
  verify [--app <name>]             Health checks; --app filters to one app
  doctor [--egress h1,h2]           Pre-bootstrap preflight — catch
                                    port/Docker/DNS/token failures up front
  open <argocd|tekton|rollouts|search|mq|registry>
                                    Print URL + creds (from INFRA.md / .env)
                                    and open the browser

$(_yellow APPLICATION)
  onboard <repo-url-or-path> [--manifests-dir <path> --lang <lang>]
                             [--dry-run] [--no-reload] [--no-up]
                             [--install-skill] [--force]
                                    Register an app described by its
                                    outpost.app.yaml. Renders a Caddy fragment
                                    + compose override; reloads caddy live and
                                    auto-starts the compose service (--no-up
                                    to opt out). --install-skill drops the
                                    LLM-side onboarding skill into the app's
                                    .claude/skills/. Accepts a git URL, a
                                    local dir, or '.'. For tier=k3s: pass
                                    --manifests-dir + --lang to scaffold k8s
                                    manifests; honors spec.k3s.manifest_repo
                                    (per-app override) over the global
                                    MANIFEST_REPO_URL.
  new-app <name> --lang <go|python|java|csharp|react|vue>
                                    Scaffold a new app from examples/hello-world/<lang>
                                    into ./my-apps/<name>/
  logs <app> [--build]              Tail container logs
                                      default: pods in 'apps' namespace
                                      --build: latest PipelineRun logs
  rollback <app>                    Roll back to the previous Healthy revision
                                    via 'argocd app rollback' (with confirmation)
  seal <app> [<KEY>=<VALUE> ...]    Wrap kubeseal — produces a SealedSecret YAML
                                    on stdout. Example:
                                      outpost seal my-app DATABASE_URL=postgres://...
  seal-from-template <app> --template <path> --output <path>
                                    Render a plaintext Secret template
                                    (envsubst) and seal it with kubeseal
  db create <app>                   Idempotently CREATE the app's Postgres DB
  manifest scaffold <app> --lang <lang> --manifests-dir <path>
                                    Scaffold deployment/service/ingress/
                                    kustomization + argocd-app from templates
                                    ([--json] machine output on all three)
  off-board <name> [--keep-running] [--remove-volumes] [--yes]
                                    Inverse of `onboard`: removes the Caddy
                                    fragment + compose override, stops the
                                    container, reloads caddy. Idempotent.
                                    For k3s-tier ArgoCD cleanup, also run
                                    `decommission`.
  decommission <app>                Guided cleanup (confirms then runs)

$(_yellow UTILITY)
  help [cmd]                        Show this or a subcommand's help
  version                           Print outpost version (git SHA)

$(_dim Source: scripts/outpost — patch via PR)
EOF
}

cmd_version() {
  local ver="unknown" sha="unknown"
  [[ -f "$OUTPOST_HOME/VERSION" ]] && ver=$(tr -d '[:space:]' < "$OUTPOST_HOME/VERSION")
  sha=$(git -C "$OUTPOST_HOME" rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo "outpost v${ver} (commit ${sha})"
}

# --- platform ---------------------------------------------------------------
cmd_status() {
  exec bash "$OUTPOST_HOME/status.sh" "$@"
}

cmd_doctor() {
  exec bash "$OUTPOST_HOME/doctor.sh" "$@"
}

cmd_verify() {
  local app=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --app) app="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  if [[ -n "$app" ]]; then
    # App-scoped checks — implements review #10 minimal version inline.
    _need kubectl
    echo "$(_green '═══') app: $app $(_green '═══')"
    echo "ArgoCD Application:"
    kubectl get application -n argocd "$app" \
      -o jsonpath='  sync:   {.status.sync.status}{"\n  health: "}{.status.health.status}{"\n  rev:    "}{.status.sync.revision}{"\n"}' \
      2>/dev/null || echo "  (not found in argocd namespace)"
    echo ""
    echo "Pods in apps namespace (label app=$app):"
    kubectl get pod -n apps -l "app=$app" 2>&1 | head -20
    echo ""
    echo "Recent PipelineRuns (label app=$app):"
    kubectl get pipelinerun -n tekton-pipelines \
      --sort-by=.metadata.creationTimestamp 2>/dev/null | grep -E "^build-${app}-" | tail -3 \
      || echo "  (none)"
    echo ""
    echo "Recent events in $app namespace (if it exists):"
    kubectl get events -n "$app" --sort-by=.lastTimestamp 2>/dev/null | tail -10 \
      || echo "  (no $app namespace)"
  else
    exec bash "$OUTPOST_HOME/verify.sh" "$@"
  fi
}

cmd_open() {
  local target="${1:-}"
  [[ -z "$target" ]] && _die "outpost open <argocd|tekton|rollouts|search|mq|registry>"
  local url user pwd
  case "$target" in
    argocd)   url="https://argocd.${ROOT_DOMAIN}";              user="admin"
              pwd="${ARGOCD_ADMIN_PASSWORD:-(re-fetch via kubectl)}" ;;
    tekton)   url="https://tekton.${ROOT_DOMAIN}";              user="${OUTPOST_DASHBOARD_USER:-outpost}"
              pwd="${OUTPOST_DASHBOARD_PASSWORD:-}" ;;
    rollouts) url="https://${ROLLOUTS_DASHBOARD_HOST:-rollouts.${ROOT_DOMAIN}}"; user="${OUTPOST_DASHBOARD_USER:-outpost}"
              pwd="${OUTPOST_DASHBOARD_PASSWORD:-}" ;;
    search)   url="https://search.${ROOT_DOMAIN}";              user="(none)"
              pwd="" ;;  # Manticore standalone has no built-in auth
    mq)       url="https://mq.${ROOT_DOMAIN}";                  user="${RABBITMQ_USER:-admin}"
              pwd="${RABBITMQ_PASSWORD:-}" ;;
    registry) url="https://registry.${ROOT_DOMAIN}";            user="(anonymous)"
              pwd="" ;;
    *) _die "unknown target: $target (try: argocd|tekton|rollouts|search|mq|registry)" ;;
  esac
  echo "$(_green URL):  $url"
  echo "$(_green User): $user"
  [[ -n "$pwd" ]] && echo "$(_green Pass): $pwd"
  echo ""
  case "$(uname -s)" in
    Darwin) open "$url" 2>/dev/null || true ;;
    Linux)  xdg-open "$url" 2>/dev/null || true ;;
  esac
}

# --- application -------------------------------------------------------------
cmd_logs() {
  local app="${1:-}"; shift || true
  [[ -z "$app" ]] && _die "outpost logs <app> [--build]"
  _need kubectl
  if [[ "${1:-}" == "--build" ]]; then
    local pr
    pr=$(kubectl get pipelinerun -n tekton-pipelines \
           --sort-by=.metadata.creationTimestamp -o name 2>/dev/null | grep "build-${app}-" | tail -1)
    [[ -z "$pr" ]] && _die "no PipelineRun found for app=$app"
    echo "$(_dim "→ $pr")"
    kubectl logs -n tekton-pipelines "$pr" --all-containers --tail=200 -f 2>/dev/null || \
      kubectl logs -n tekton-pipelines "$pr" --all-containers --tail=200
  else
    echo "$(_dim "→ kubectl logs -n apps -l app=$app -f --all-containers")"
    kubectl logs -n apps -l "app=$app" --all-containers --tail=200 -f
  fi
}

cmd_rollback() {
  local app="${1:-}"
  [[ -z "$app" ]] && _die "outpost rollback <app>"
  _need kubectl
  _need argocd 2>/dev/null || true   # warn but continue — kubectl-only fallback below

  echo "Current state:"
  kubectl get application -n argocd "$app" \
    -o jsonpath='  rev: {.status.sync.revision}{"\n"}' 2>/dev/null \
    || _die "no ArgoCD Application named $app"

  if ! _confirm "Roll back $app to the previous Healthy revision?"; then
    echo "Cancelled."; exit 0
  fi

  if command -v argocd >/dev/null 2>&1 && [[ -n "${ARGOCD_ADMIN_PASSWORD:-}" ]]; then
    argocd login "argocd.${ROOT_DOMAIN}" --username admin --password "$ARGOCD_ADMIN_PASSWORD" --insecure 2>/dev/null || true
    argocd app rollback "$app" 0 || _die "argocd app rollback failed"
  else
    echo "$(_yellow 'no argocd CLI / no ARGOCD_ADMIN_PASSWORD'): use the ArgoCD UI:"
    echo "  https://argocd.${ROOT_DOMAIN}/applications/$app  → click HISTORY AND ROLLBACK"
    echo ""
    echo "Or revert the latest 'chore($app): bump image' commit in the manifest repo."
  fi
}

cmd_seal() {
  local app="${1:-}"; shift || true
  [[ -z "$app" ]] && _die "outpost seal <app> [<KEY>=<VALUE> ...]"
  _need kubeseal
  _need kubectl

  local tmp; tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT

  cat > "$tmp" <<EOF
apiVersion: v1
kind: Secret
metadata:
  name: ${app}-secrets
  namespace: apps
type: Opaque
stringData:
EOF
  if [[ $# -eq 0 ]]; then
    cat <<EOF >&2
$(_yellow 'No KEY=VALUE pairs supplied.') Reading stringData from stdin (one per line, KEY=VALUE):

  $(_dim "DATABASE_URL=postgres://...")
  $(_dim "REDIS_URL=redis://...")
  $(_dim "(Ctrl-D when done)")
EOF
    while IFS= read -r line; do
      [[ -z "$line" || "$line" =~ ^# ]] && continue
      [[ "$line" =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]] || _die "bad line: $line"
      printf '  %s: %q\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" >> "$tmp"
    done
  else
    for kv in "$@"; do
      [[ "$kv" =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]] || _die "bad arg: $kv (expect KEY=VALUE)"
      printf '  %s: %q\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" >> "$tmp"
    done
  fi

  echo "$(_dim '→ kubeseal --controller-namespace=kube-system --format=yaml')"
  kubeseal --controller-namespace=kube-system --format=yaml < "$tmp"
  echo "" >&2
  echo "$(_green '✓') Pipe the YAML above into a file and commit it to the manifest repo." >&2
  echo "  e.g.  outpost seal $app KEY=val | tee apps/$app/sealed-secret.yaml" >&2
}

cmd_new_app() {
  local name="${1:-}"
  [[ -z "$name" ]] && _die "outpost new-app <name> --lang <go|python|java|csharp|react|vue>"
  shift
  local lang=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang) lang="${2:-}"; shift 2 ;;
      *) shift ;;
    esac
  done
  [[ -z "$lang" ]] && _die "--lang is required (one of: go python java csharp react vue)"

  local src="examples/hello-world/$lang"
  [[ -d "$src" ]] || _die "no template at $src — supported langs: $(ls examples/hello-world/ | grep -v README | tr '\n' ' ')"

  local dst="my-apps/$name"
  [[ -e "$dst" ]] && _die "$dst already exists"
  mkdir -p my-apps
  cp -r "$src" "$dst"

  # Rename inside the copy: hello-<lang> / hello-world-<lang> → <name>
  find "$dst" -type f \( -name '*.yaml' -o -name '*.md' -o -name 'Dockerfile' -o -name 'main.*' \) | while read -r f; do
    portable_sed_i="-i"; [[ "$(uname -s)" == "Darwin" ]] && portable_sed_i="-i ''"
    # shellcheck disable=SC2086
    sed $portable_sed_i \
      -e "s|hello-world-${lang}|${name}|g" \
      -e "s|hello-${lang}|${name}|g" \
      "$f"
  done

  echo "$(_green '✓') Scaffolded $dst from $src"
  echo ""
  echo "Next steps:"
  echo "  1. Edit $dst/manifest/*.yaml — set your image, ingress hostname, replicas"
  echo "  2. Push your application code (with a Dockerfile at the root) to a git repo"
  echo "  3. Copy $dst/manifest/ into your manifest repo as apps/$name/"
  echo "  4. Configure the webhook on your application repo (see 05-onboard-project.md §5)"
  echo "  5. ArgoCD picks up the change within ~30s"
}

cmd_decommission() {
  local app="${1:-}"
  [[ -z "$app" ]] && _die "outpost decommission <app>"
  _need kubectl

  echo "$(_yellow WARNING): this will:"
  echo "  - delete ArgoCD Application '$app' (cascades to K8s resources)"
  echo "  - print git commands for you to run in the manifest repo"
  echo "  - leave registry images intact (manual cleanup if needed)"
  echo ""
  if ! _confirm "Continue?"; then
    echo "Cancelled."; exit 0
  fi

  echo ""
  echo "$(_dim '→') kubectl delete application -n argocd $app --cascade=foreground"
  kubectl delete application -n argocd "$app" --cascade=foreground 2>&1 | head -5 || true

  echo ""
  echo "$(_green '✓') ArgoCD Application removed."
  echo ""
  echo "Now in your manifest repo:"
  cat <<EOF
  cd <manifest-repo>
  git rm -r apps/$app/
  git rm argocd-apps/${app}.yaml
  git commit -m "chore: decommission $app"
  git push
EOF
  echo ""
  echo "Optional registry image cleanup (self-hosted):"
  echo "  curl -X DELETE -u .. https://registry.${ROOT_DOMAIN}/v2/$app/manifests/<digest>"
  echo "  (Aliyun ACR: use the ACR console)"
}

# --- onboard primitives (v0.4 Phase 3) ---------------------------------------
# Generic onboarding *mechanism*; app *content* enters only as args / .env
# (ADR 0002). Each command: human output by default, locked JSON under --json
# (schema: tests/schema/onboard-output.schema.json), idempotent, exit 0/1/2.

# _onboard_report <json:0|1> <step> <status> <detail> <next_action> [<file>...]
# json=1 → emit the locked JSON object (stdout only). json=0 → human lines.
_onboard_report() {
  local json="$1" step="$2" status="$3" detail="$4" next_action="$5"
  shift 5
  if [[ "$json" -eq 1 ]]; then
    onboard_emit_json "$step" "$status" "$detail" "$next_action" "$@"
    return 0
  fi
  case "$status" in
    error) err  "$detail" ;;
    drift) warn "$detail" ;;
    *)     ok   "$detail" ;;
  esac
  local f
  for f in "$@"; do
    echo "       $(_dim "· $f")"
  done
  [[ -n "$next_action" ]] && echo "       $(_dim "↳ next: $next_action")"
  return 0
}

# outpost db create <app> [--json] — idempotent CREATE DATABASE.
cmd_db() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    create) _db_create "$@" ;;
    *)      _die "outpost db create <app> [--json]" ;;
  esac
}

_db_create() {
  local app="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=1; shift ;;
      -*)     _die "unknown flag: $1" ;;
      *)      [[ -z "$app" ]] && app="$1"; shift ;;
    esac
  done
  [[ -z "$app" ]] && _die "outpost db create <app> [--json]"
  _need docker

  local db pguser step="db.create" status detail next_action exists
  db="$(onboard_db_name "$app")"
  pguser="${POSTGRES_USER:-postgres}"
  next_action="reference the database in the app's secret template, then: outpost seal-from-template"

  # Existence check — idempotent. Connect to the always-present 'postgres'
  # maintenance DB. A failed docker exec = the data layer is not up.
  if ! exists="$(docker exec postgres psql -U "$pguser" -d postgres -tAc \
       "SELECT 1 FROM pg_database WHERE datname='$db'" 2>/dev/null)"; then
    _onboard_report "$json" "$step" error \
      "cannot reach the postgres container — is the data layer running?" \
      "start it: docker compose -f core/compose/docker-compose.yml up -d postgres"
    exit 1
  fi

  if [[ "$exists" == "1" ]]; then
    status="exists"; detail="database \"$db\" already present"
  else
    if ! docker exec postgres psql -U "$pguser" -d postgres \
         -c "CREATE DATABASE \"$db\"" >/dev/null 2>&1; then
      _onboard_report "$json" "$step" error \
        "CREATE DATABASE \"$db\" failed" "inspect postgres logs: docker logs postgres"
      exit 1
    fi
    status="created"; detail="database \"$db\" created"
  fi
  _onboard_report "$json" "$step" "$status" "$detail" "$next_action"
  exit 0
}

# outpost seal-from-template <app> --template <p> --output <p> [--json]
# Render a plaintext Secret template (envsubst + strict ${VAR} residue check),
# then seal it with kubeseal. NOTE: SealedSecret ciphertext is randomised —
# re-running always (re)writes <output>; idempotency holds at the plaintext
# level (same template + env → same decrypted Secret), not byte-for-byte.
cmd_seal_from_template() {
  local app="" template="" output="" json=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --template) template="${2:-}"; shift 2 ;;
      --output)   output="${2:-}";   shift 2 ;;
      --json)     json=1; shift ;;
      -*)         _die "unknown flag: $1" ;;
      *)          [[ -z "$app" ]] && app="$1"; shift ;;
    esac
  done
  [[ -z "$app" ]]      && _die "outpost seal-from-template <app> --template <path> --output <path> [--json]"
  [[ -z "$template" ]] && _die "--template <path> is required"
  [[ -z "$output" ]]   && _die "--output <path> is required"
  _need kubeseal
  _need envsubst

  local step="seal.from-template"
  if [[ ! -r "$template" ]]; then
    _onboard_report "$json" "$step" error "template not readable: $template" \
      "create the plaintext Secret template (\${VAR} placeholders) first"
    exit 1
  fi

  local tmp; tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  # render_template aborts (non-zero + stderr detail) on any unresolved
  # ${VAR} — better an explicit failure than a sealed empty value.
  if ! render_template "$template" "$tmp"; then
    _onboard_report "$json" "$step" error \
      "template has unresolved \${VAR} placeholders (see message above)" \
      "export the missing variables, then retry"
    exit 1
  fi

  mkdir -p "$(dirname "$output")"
  if ! kubeseal --controller-namespace=kube-system --format=yaml < "$tmp" > "$output" 2>/dev/null; then
    rm -f "$output"
    _onboard_report "$json" "$step" error \
      "kubeseal failed — is the sealed-secrets controller running?" \
      "check: kubectl -n kube-system get pods -l name=sealed-secrets-controller"
    exit 1
  fi

  _onboard_report "$json" "$step" sealed "sealed → $output" \
    "commit $output to the manifests repo (apps/$app/)" "$output"
  exit 0
}

# outpost manifest scaffold <app> --lang <l> --manifests-dir <d> [--json] [--force]
cmd_manifest() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    scaffold) _manifest_scaffold "$@" ;;
    *)        _die "outpost manifest scaffold <app> --lang <lang> --manifests-dir <path> [--json] [--force]" ;;
  esac
}

# Generic, generated kustomization.yaml (avoids depending on each language
# example shipping one — only go's does today).
_scaffold_kustomization() {
  local app="$1" image="$2"
  cat <<EOF
# Kustomize-managed image override. Tekton's update-manifest task rewrites
# the matching images[] entry's newTag on every successful build.
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - deployment.yaml
  - service.yaml
  - ingress.yaml

images:
  - name: ${image}
    newName: ${image}
    newTag: placeholder
EOF
}

_manifest_scaffold() {
  local app="" lang="" mdir="" json=0 force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)          lang="${2:-}"; shift 2 ;;
      --manifests-dir) mdir="${2:-}"; shift 2 ;;
      --json)          json=1; shift ;;
      --force)         force=1; shift ;;
      -*)              _die "unknown flag: $1" ;;
      *)               [[ -z "$app" ]] && app="$1"; shift ;;
    esac
  done
  [[ -z "$app" ]]  && _die "outpost manifest scaffold <app> --lang <lang> --manifests-dir <path> [--json] [--force]"
  [[ -z "$lang" ]] && _die "--lang <lang> is required"
  [[ -z "$mdir" ]] && _die "--manifests-dir <path> is required"

  local src="$OUTPOST_HOME/examples/hello-world/$lang/manifest"
  [[ -d "$src" ]] || _die "unknown --lang '$lang' — supported: $(ls "$OUTPOST_HOME/examples/hello-world" | grep -v README | tr '\n' ' ')"
  [[ -d "$mdir" ]] || _die "--manifests-dir does not exist: $mdir (clone the manifests repo first)"

  local f
  for f in deployment.yaml service.yaml ingress.yaml; do
    [[ -r "$src/$f" ]] || _die "template missing: $src/$f (the $lang example is incomplete)"
  done

  local step="manifest.scaffold"
  local appdir="$mdir/apps/$app" argodir="$mdir/argocd-apps"
  mkdir -p "$appdir" "$argodir"

  local registry domain repo_url repo_branch
  # The host the build pipeline pushes to — keeps the scaffolded kustomization
  # images[].name matching what update-manifest rewrites on the first build.
  registry="${REGISTRY_PUSH_HOST:-${REGISTRY_HOST:-registry.example.com}}"
  domain="${ROOT_DOMAIN:-example.com}"
  repo_url="${MANIFEST_REPO_URL:-https://example.com/your/infras-manifests.git}"
  repo_branch="${MANIFEST_REPO_BRANCH:-main}"

  # Substitutions shared by deployment / service / ingress.
  local subst=(
    "s|hello-world-${lang}|${app}|g"
    "s|hello-${lang}|${app}|g"
    "s|registry\\.example\\.com|${registry}|g"
    "s|apps\\.example\\.com|apps.${domain}|g"
  )

  local tmpdir; tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  onboard_render_subst "$src/deployment.yaml" "$tmpdir/deployment.yaml" "${subst[@]}"
  onboard_render_subst "$src/service.yaml"    "$tmpdir/service.yaml"    "${subst[@]}"
  onboard_render_subst "$src/ingress.yaml"    "$tmpdir/ingress.yaml"    "${subst[@]}"
  _scaffold_kustomization "$app" "${registry}/${app}" > "$tmpdir/kustomization.yaml"
  onboard_render_subst "$OUTPOST_HOME/examples/demo-app/argocd-application.yaml" \
    "$tmpdir/argocd-application.yaml" \
    "s|demo-app|${app}|g" \
    "s|https://gitee.com/<your-user>/infras-manifests.git|${repo_url}|g" \
    "s|targetRevision: main|targetRevision: ${repo_branch}|g"

  # Place the 5 files idempotently: absent → write; identical → skip;
  # drifted → leave untouched (unless --force) so hand edits are never lost.
  local written=() drifted=0 unchanged=0
  local pairs=(
    "$tmpdir/deployment.yaml|$appdir/deployment.yaml"
    "$tmpdir/service.yaml|$appdir/service.yaml"
    "$tmpdir/ingress.yaml|$appdir/ingress.yaml"
    "$tmpdir/kustomization.yaml|$appdir/kustomization.yaml"
    "$tmpdir/argocd-application.yaml|$argodir/$app.yaml"
  )
  local pair tmpf dstf
  for pair in "${pairs[@]}"; do
    tmpf="${pair%%|*}"; dstf="${pair#*|}"
    if [[ ! -e "$dstf" ]]; then
      cp "$tmpf" "$dstf"; written+=("$dstf")
    elif onboard_files_identical "$tmpf" "$dstf"; then
      unchanged=$((unchanged + 1))
    elif [[ "$force" -eq 1 ]]; then
      cp "$tmpf" "$dstf"; written+=("$dstf")
    else
      drifted=$((drifted + 1))
    fi
  done

  local status detail next_action
  if [[ "$drifted" -gt 0 ]]; then
    status="drift"
    detail="$drifted of 5 file(s) differ from the scaffold; not overwritten"
    next_action="inspect the differing file(s), or re-run with --force to overwrite"
  elif [[ ${#written[@]} -eq 0 ]]; then
    status="unchanged"
    detail="all 5 manifest file(s) already match the scaffold"
    next_action="nothing to do — manifests are up to date"
  else
    status="scaffolded"
    detail="scaffolded ${#written[@]} file(s) under $mdir"
    next_action="review the scaffolded file(s), then commit them to the manifests repo"
  fi

  if [[ ${#written[@]} -gt 0 ]]; then
    _onboard_report "$json" "$step" "$status" "$detail" "$next_action" "${written[@]}"
  else
    _onboard_report "$json" "$step" "$status" "$detail" "$next_action"
  fi
  [[ "$status" == "drift" ]] && exit 2
  exit 0
}

# --- onboard ----------------------------------------------------------------
# `outpost onboard <repo-or-path>` — register an app described by its
# outpost.app.yaml into the running infras instance. Idempotent:
# re-running with the same yaml is a no-op (fragment + override files
# only get rewritten if their content changed).
#
# Accepts:
#   <local-dir>           — treated as a path, looks for outpost.app.yaml at root
#   <git-url>             — cloned shallow into a temp dir; cleaned up on exit
#   .                     — shorthand for CWD
#
# Side effects (after a successful render):
#   1. core/compose/Caddyfile.d/<name>.caddy  ← Caddy route fragment
#   2. core/compose/overrides/<name>.yml      ← compose override (tier=compose only)
#   3. `docker exec caddy caddy reload`       ← live config swap if caddy is running
#
# For tier=k3s, this delegates to the existing `outpost manifest scaffold` flow;
# the manifest_repo can be overridden per-app via spec.k3s.manifest_repo.
cmd_onboard() {
  local src_arg="" tmpdir="" cleanup=0
  local dry_run=0 no_reload=0 no_up=0 force=0 install_skill=0
  local manifests_dir="" lang=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)        dry_run=1; shift ;;
      --no-reload)      no_reload=1; shift ;;
      --no-up)          no_up=1; shift ;;
      --force)          force=1; shift ;;
      --install-skill)  install_skill=1; shift ;;
      --manifests-dir)  manifests_dir="${2:-}"; shift 2 ;;
      --lang)           lang="${2:-}"; shift 2 ;;
      -*)               _die "unknown flag: $1" ;;
      *)                [[ -z "$src_arg" ]] && src_arg="$1"; shift ;;
    esac
  done
  [[ -z "$src_arg" ]] && _die "outpost onboard <repo-url-or-path> [--manifests-dir <path> --lang <lang>] [--dry-run] [--no-reload] [--no-up] [--install-skill] [--force]"
  _need yq

  # Resolve src_arg to a local directory containing outpost.app.yaml.
  local src_dir=""
  case "$src_arg" in
    .)                   src_dir="$PWD" ;;
    /*|./*|../*)         src_dir="$src_arg" ;;
    *://*|git@*:*|*@*:*) # URL-ish — clone shallow
      _need git
      tmpdir="$(mktemp -d)"
      cleanup=1
      # shellcheck disable=SC2064  # tmpdir is captured by value
      trap "[[ -n '$tmpdir' && -d '$tmpdir' ]] && rm -rf '$tmpdir'" EXIT INT TERM
      echo "$(_dim Cloning) $src_arg → $tmpdir"
      git clone --depth 1 --quiet "$src_arg" "$tmpdir/repo" || _die "git clone failed: $src_arg"
      src_dir="$tmpdir/repo"
      ;;
    *)
      if [[ -d "$src_arg" ]]; then
        src_dir="$src_arg"
      else
        _die "not a directory or recognized URL: $src_arg"
      fi
      ;;
  esac

  local cfg="$src_dir/outpost.app.yaml"
  if [[ ! -r "$cfg" ]]; then
    _die "no outpost.app.yaml at $src_dir (see examples/outpost.app.yaml.minimal.example)"
  fi

  onboard_app_validate "$cfg" || _die "outpost.app.yaml validation failed"

  local name tier
  name=$(yq -r '.metadata.name' "$cfg")
  tier=$(yq -r '.spec.tier' "$cfg")

  local caddy_dst="$OUTPOST_HOME/core/compose/Caddyfile.d/${name}.caddy"
  local override_dst="$OUTPOST_HOME/core/compose/overrides/${name}.yml"
  local rendered_caddy rendered_compose
  rendered_caddy=$(onboard_render_caddy_fragment "$cfg")

  echo "$(_green onboard): app=$name tier=$tier source=$src_dir"

  if [[ "$dry_run" -eq 1 ]]; then
    echo "$(_yellow DRY RUN) — would write:"
    echo "  $caddy_dst"
    [[ "$tier" == "compose" ]] && echo "  $override_dst"
    echo "$(_dim --- Caddy fragment ---)"
    printf '%s\n' "$rendered_caddy"
    if [[ "$tier" == "compose" ]]; then
      echo "$(_dim --- Compose override ---)"
      onboard_render_compose_override "$cfg"
    fi
    return 0
  fi

  # Write Caddy fragment. Refuse to clobber a drifted fragment unless --force.
  mkdir -p "$(dirname "$caddy_dst")"
  if [[ -f "$caddy_dst" && "$force" -ne 1 ]]; then
    if [[ "$rendered_caddy" == "$(cat "$caddy_dst")" ]]; then
      echo "$(_dim ✓) Caddyfile.d/${name}.caddy unchanged"
    else
      _die "Caddyfile.d/${name}.caddy differs from rendered output. Re-run with --force to overwrite."
    fi
  else
    printf '%s\n' "$rendered_caddy" > "$caddy_dst"
    echo "$(_green ✓) wrote $caddy_dst"
  fi

  if [[ "$tier" == "compose" ]]; then
    mkdir -p "$(dirname "$override_dst")"
    rendered_compose=$(onboard_render_compose_override "$cfg")
    if [[ -f "$override_dst" && "$force" -ne 1 ]]; then
      if [[ "$rendered_compose" == "$(cat "$override_dst")" ]]; then
        echo "$(_dim ✓) overrides/${name}.yml unchanged"
      else
        _die "overrides/${name}.yml differs from rendered output. Re-run with --force to overwrite."
      fi
    else
      printf '%s\n' "$rendered_compose" > "$override_dst"
      echo "$(_green ✓) wrote $override_dst"
    fi
    # Auto-start the new service, unless the operator opted out. We bring up
    # just the named service (not the full stack) to minimise side effects on
    # already-running data services. status.sh + bootstrap.d/04-compose.sh
    # glob overrides/*.yml so subsequent restarts pick this up naturally.
    if [[ "$no_up" -ne 1 ]] && command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
      if ( cd "$OUTPOST_HOME/core/compose" && \
           docker compose --env-file "$OUTPOST_HOME/.env" \
             -f docker-compose.yml \
             -f "overrides/${name}.yml" \
             up -d "${name}" >/dev/null 2>&1 ); then
        echo "$(_green ✓) started service: ${name}"
      else
        echo "$(_yellow !) docker compose up failed — start manually:"
        echo "$(_dim    ) cd core/compose && docker compose -f docker-compose.yml -f overrides/${name}.yml up -d ${name}"
      fi
    else
      echo "$(_dim hint:) start the new service with"
      echo "  cd core/compose && docker compose -f docker-compose.yml -f overrides/${name}.yml up -d ${name}"
    fi
  elif [[ "$tier" == "k3s" ]]; then
    # Read the per-app overrides. Each field passes through envsubst so the
    # outpost.app.yaml author can write `${MY_APP_MANIFEST_REPO:-...}` to
    # gate the value on a caller-set env var (useful when one repo is
    # onboarded against different infras instances).
    local per_app_repo per_app_branch per_app_path
    per_app_repo=$(yq -r '.spec.k3s.manifest_repo // ""' "$cfg" | envsubst)
    per_app_branch=$(yq -r '.spec.k3s.manifest_branch // ""' "$cfg" | envsubst)
    per_app_path=$(yq -r '.spec.k3s.manifest_path // ""' "$cfg" | envsubst)

    # Per-app override wins; else fall through to the global MANIFEST_REPO_URL
    # (set in .env at install time). Same precedence rule applies to branch.
    local resolved_repo="${per_app_repo:-${MANIFEST_REPO_URL:-}}"
    local resolved_branch="${per_app_branch:-${MANIFEST_REPO_BRANCH:-main}}"

    if [[ -z "$manifests_dir" ]]; then
      echo "$(_yellow !) tier=k3s but --manifests-dir not given — onboard rendered the Caddy fragment only"
      echo "$(_dim hint:) clone the manifests repo locally and re-run with:"
      echo "  outpost onboard $src_arg --manifests-dir <local-clone> --lang <go|python|java|csharp|react|vue>"
      if [[ -n "$per_app_repo" ]]; then
        echo "$(_dim hint:) this app overrides MANIFEST_REPO_URL to: $resolved_repo"
      fi
      return 0
    fi

    [[ -z "$lang" ]] && _die "--lang is required when --manifests-dir is set (one of: $(ls "$OUTPOST_HOME/examples/hello-world" 2>/dev/null | grep -v README | tr '\n' ' '))"
    if [[ -z "$resolved_repo" ]]; then
      _die "no manifest repo to wire — set spec.k3s.manifest_repo in $cfg, or MANIFEST_REPO_URL in .env"
    fi

    echo "$(_green k3s) scaffolding manifests into $manifests_dir"
    echo "  repo:   $resolved_repo"
    echo "  branch: $resolved_branch"
    [[ -n "$per_app_path" ]] && echo "  path:   $per_app_path (custom)"

    # Scoped env override: temporarily replace MANIFEST_REPO_URL /
    # MANIFEST_REPO_BRANCH so _manifest_scaffold (which reads them) emits
    # the per-app values into the rendered argocd-app.yaml. Restored when
    # the subshell exits — no global pollution. Run as two branches rather
    # than a `${arr[@]}`-with-empty-array trick: bash 3.2 (macOS default)
    # under `set -u` errors on empty-array expansion.
    if [[ "$force" -eq 1 ]]; then
      (
        export MANIFEST_REPO_URL="$resolved_repo"
        export MANIFEST_REPO_BRANCH="$resolved_branch"
        _manifest_scaffold "$name" --lang "$lang" --manifests-dir "$manifests_dir" --force
      )
    else
      (
        export MANIFEST_REPO_URL="$resolved_repo"
        export MANIFEST_REPO_BRANCH="$resolved_branch"
        _manifest_scaffold "$name" --lang "$lang" --manifests-dir "$manifests_dir"
      )
    fi
  fi

  # Reload Caddy if running (no-op if container is stopped).
  if [[ "$no_reload" -ne 1 ]] && command -v docker >/dev/null 2>&1; then
    if docker inspect -f '{{.State.Running}}' caddy 2>/dev/null | grep -q true; then
      if docker exec caddy caddy reload --config /etc/caddy/Caddyfile >/dev/null 2>&1; then
        echo "$(_green ✓) caddy reloaded"
      else
        echo "$(_yellow !) caddy reload failed — fragment written but config not live yet"
        echo "$(_dim    run:) docker exec caddy caddy reload --config /etc/caddy/Caddyfile"
      fi
    else
      echo "$(_dim ·) caddy container not running — fragment will load on next \`docker compose up\`"
    fi
  fi

  # Optional: drop the LLM-side onboarding skill template into the app's
  # repo so future Claude/Cursor sessions auto-discover the onboarding
  # flow. Idempotent — `cp -n` style: existing target is preserved.
  if [[ "$install_skill" -eq 1 ]]; then
    local skill_src="$OUTPOST_HOME/docs/onboarding/outpost-app.skill.md"
    local skill_dst_dir="$src_dir/.claude/skills"
    local skill_dst="$skill_dst_dir/outpost-deploy.skill.md"
    if [[ ! -r "$skill_src" ]]; then
      echo "$(_yellow !) skill template not found at $skill_src — skipping --install-skill"
    elif [[ -f "$skill_dst" && "$force" -ne 1 ]]; then
      echo "$(_dim ·) skill already at $skill_dst (--force to overwrite)"
    else
      mkdir -p "$skill_dst_dir"
      cp "$skill_src" "$skill_dst"
      echo "$(_green ✓) installed skill template → $skill_dst"
      echo "$(_dim hint:) commit \`.claude/skills/outpost-deploy.skill.md\` to share onboarding with the team"
    fi
  fi
}

# --- off-board ---------------------------------------------------------------
# Inverse of `outpost onboard`: remove the Caddyfile.d/<name>.caddy fragment,
# the overrides/<name>.yml compose override, and (unless --keep-running) stop
# the named compose service. Idempotent — missing artefacts are tolerated.
#
# Does NOT delete data volumes by default. Pass --remove-volumes to also drop
# named volumes the container declared (irreversible — confirms unless --yes).
#
# For tier=k3s apps, this only handles the local infras-side artefacts. To
# remove the ArgoCD Application + manifests-repo files, use the existing
# `outpost decommission` command.
cmd_off_board() {
  local name="" keep_running=0 remove_volumes=0 yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-running)   keep_running=1; shift ;;
      --remove-volumes) remove_volumes=1; shift ;;
      --yes|-y)         yes=1; shift ;;
      -*)               _die "unknown flag: $1" ;;
      *)                [[ -z "$name" ]] && name="$1"; shift ;;
    esac
  done
  [[ -z "$name" ]] && _die "outpost off-board <name> [--keep-running] [--remove-volumes] [--yes]"

  local frag="$OUTPOST_HOME/core/compose/Caddyfile.d/${name}.caddy"
  local override="$OUTPOST_HOME/core/compose/overrides/${name}.yml"

  local found=0
  [[ -f "$frag" ]] && found=1
  [[ -f "$override" ]] && found=1
  if [[ "$found" -eq 0 ]]; then
    echo "$(_dim ·) no artefacts found for '${name}' (Caddyfile.d/, overrides/) — nothing to off-board"
    return 0
  fi

  if [[ "$remove_volumes" -eq 1 && "$yes" -ne 1 ]]; then
    if ! _confirm "remove data volumes for '${name}'? this is destructive."; then
      _die "aborted by user"
    fi
  fi

  # Stop the running container (if any). Use the override file so compose
  # knows about the service definition; tolerate failures (container may
  # have never been started, or already gone).
  if [[ "$keep_running" -ne 1 && -f "$override" ]] && command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    local down_args=()
    [[ "$remove_volumes" -eq 1 ]] && down_args=(-v)
    if [[ ${#down_args[@]} -gt 0 ]]; then
      ( cd "$OUTPOST_HOME/core/compose" && \
        docker compose --env-file "$OUTPOST_HOME/.env" \
          -f docker-compose.yml \
          -f "overrides/${name}.yml" \
          stop "${name}" >/dev/null 2>&1 || true; \
        docker compose --env-file "$OUTPOST_HOME/.env" \
          -f docker-compose.yml \
          -f "overrides/${name}.yml" \
          rm -f -s "${down_args[@]}" "${name}" >/dev/null 2>&1 || true )
    else
      ( cd "$OUTPOST_HOME/core/compose" && \
        docker compose --env-file "$OUTPOST_HOME/.env" \
          -f docker-compose.yml \
          -f "overrides/${name}.yml" \
          stop "${name}" >/dev/null 2>&1 || true; \
        docker compose --env-file "$OUTPOST_HOME/.env" \
          -f docker-compose.yml \
          -f "overrides/${name}.yml" \
          rm -f "${name}" >/dev/null 2>&1 || true )
    fi
    echo "$(_green ✓) stopped + removed container: ${name}"
  fi

  # Delete the artefacts.
  if [[ -f "$frag" ]]; then
    rm -f "$frag"
    echo "$(_green ✓) removed $frag"
  fi
  if [[ -f "$override" ]]; then
    rm -f "$override"
    echo "$(_green ✓) removed $override"
  fi

  # Reload Caddy so the deleted fragment really goes away.
  if command -v docker >/dev/null 2>&1; then
    if docker inspect -f '{{.State.Running}}' caddy 2>/dev/null | grep -q true; then
      if docker exec caddy caddy reload --config /etc/caddy/Caddyfile >/dev/null 2>&1; then
        echo "$(_green ✓) caddy reloaded"
      else
        echo "$(_yellow !) caddy reload failed — config may still serve the old route until next restart"
      fi
    fi
  fi

  echo "$(_dim ·) off-board complete for '${name}'"
  echo "$(_dim hint:) for tier=k3s apps, also run \`outpost decommission ${name}\` to remove the ArgoCD Application"
}

# --- router ------------------------------------------------------------------
SUB="${1:-help}"
shift || true
case "$SUB" in
  status)         cmd_status "$@" ;;
  verify)         cmd_verify "$@" ;;
  doctor)         cmd_doctor "$@" ;;
  open)           cmd_open "$@" ;;
  logs)           cmd_logs "$@" ;;
  rollback)       cmd_rollback "$@" ;;
  seal)           cmd_seal "$@" ;;
  seal-from-template) cmd_seal_from_template "$@" ;;
  db)             cmd_db "$@" ;;
  manifest)       cmd_manifest "$@" ;;
  new-app)        cmd_new_app "$@" ;;
  onboard)        cmd_onboard "$@" ;;
  off-board)      cmd_off_board "$@" ;;
  decommission)   cmd_decommission "$@" ;;
  version|--version|-v) cmd_version ;;
  help|--help|-h|"") usage ;;
  *) echo "$(_red unknown): $SUB"; usage; exit 1 ;;
esac
