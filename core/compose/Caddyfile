# =============================================================================
# Caddy — internal HTTP reverse proxy
# -----------------------------------------------------------------------------
# - cloudflared forwards HTTP traffic for data UI subdomains here
# - Caddy routes by Host header
# - TLS is terminated at the Cloudflare edge — internal traffic is plain HTTP
# - All host prefixes and upstreams are env-var driven (Caddy's {$VAR:default}
#   syntax). Override in .env to relocate routes without forking this file.
# - App-specific routes go in ./Caddyfile.d/*.caddy fragments — never edit
#   this file to add an application route. See `outpost onboard` (the CLI
#   subcommand) and docs/onboarding/example-fragments/ for the pattern.
# =============================================================================

{
    auto_https off
    admin off
    servers {
        trusted_proxies static private_ranges
    }
}

:80 {
    # ----- built-in data-service UIs ----------------------------------------
    # SEARCH_HOST / SEARCH_UPSTREAM / MQ_HOST / MQ_UPSTREAM all default to the
    # in-network container names. Override only if you swap implementations or
    # need different subdomain prefixes for your org.
    @search host {$SEARCH_HOST:search}.{$ROOT_DOMAIN}
    handle @search {
        reverse_proxy {$SEARCH_UPSTREAM:manticore:9308}
    }

    @mq host {$MQ_HOST:mq}.{$ROOT_DOMAIN}
    handle @mq {
        reverse_proxy {$MQ_UPSTREAM:rabbitmq:15672}
    }

    # ----- app-defined route fragments --------------------------------------
    # Each onboarded app drops one `.caddy` file in Caddyfile.d/ (via
    # `outpost onboard <repo>`). Adding routes here directly is an anti-pattern:
    # it forks the infras repo per consumer and breaks `git pull` upgrades.
    import /etc/caddy/Caddyfile.d/*.caddy

    handle {
        respond "Unknown host: {host}" 404
    }
}
