# =============================================================================
# Outpost — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. `bootstrap.sh` will auto-generate any blank
# password fields. The `.env` file is gitignored — never commit it.
# =============================================================================

# ---- Mode ----
# local : Compose data services only (PG / Redis / RabbitMQ / Meilisearch on
#         localhost). No Cloudflare Tunnel, no k3s, no GitOps. Zero required
#         input — `bash bootstrap.sh` runs end-to-end with all defaults.
# full  : Everything above + Cloudflare Tunnel + k3s + ArgoCD + Tekton CI/CD.
#         Requires ROOT_DOMAIN, CF_TUNNEL_TOKEN, GIT_USER, GIT_TOKEN,
#         MANIFEST_REPO_URL.
OUTPOST_MODE=local

# ---- Domain ----
# Required for `full` mode. Ignored in `local` mode (defaults to outpost.local).
ROOT_DOMAIN=

# ---- Cloudflare Tunnel ----
# Required for `full` mode only. Get from Cloudflare Dashboard → Zero Trust →
# Networks → Tunnels → Create.
CF_TUNNEL_TOKEN=

# ---- Platform plugins ----
# Registry plugin — see plugins/registry/<name>/ for available choices.
# Built-in: self-hosted (default), aliyun-acr
REGISTRY_PLUGIN=self-hosted

# Git provider plugin — Tekton EventListener triggers.
# Built-in: gitee (default), github, gitlab
GIT_PROVIDER_PLUGIN=gitee

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ---- Redis ----
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# ---- Meilisearch ----
MEILI_MASTER_KEY=
MEILI_ENV=production

# ---- Git provider credentials (full mode only) ----
# Used by ArgoCD to pull manifest repo and Tekton to clone app repos.
GIT_USER=
GIT_TOKEN=

# Webhook secret — Tekton EventListener verifies this against incoming hooks.
# Auto-generated if blank.
GIT_WEBHOOK_SECRET=

# ---- Manifest repository (ArgoCD source-of-truth, full mode only) ----
# HTTPS URL ending in .git
MANIFEST_REPO_URL=
MANIFEST_REPO_BRANCH=main

# Auto-derived by bootstrap.sh from MANIFEST_REPO_URL (e.g. gitee.com /
# github.com / gitlab.com). Used by Tekton's git credentials Secret.
# Leave blank — bootstrap will populate it on first run.
GIT_HOST=

# ---- Aliyun ACR (only if REGISTRY_PLUGIN=aliyun-acr) ----
ALIYUN_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_ACR_NAMESPACE=
ALIYUN_ACR_USER=
ALIYUN_ACR_PASSWORD=
