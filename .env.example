# =============================================================================
# Outpost — environment template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in. `bootstrap.sh` will auto-generate any blank
# password fields. The `.env` file is gitignored — never commit it.
# =============================================================================

# ---- Mode ----
# local : Compose data services only (PG / Redis / RabbitMQ / Manticore on
#         localhost). No Cloudflare Tunnel, no k3s, no GitOps. Zero required
#         input — `bash bootstrap.sh` runs end-to-end with all defaults.
# full  : Everything above + Cloudflare Tunnel + k3s + ArgoCD + Tekton CI/CD.
#         Requires ROOT_DOMAIN, CF_TUNNEL_TOKEN, GIT_USER, GIT_TOKEN,
#         MANIFEST_REPO_URL.
OUTPOST_MODE=local

# ---- Domain ----
# Required for `full` mode. Ignored in `local` mode (defaults to outpost.local).
ROOT_DOMAIN=

# ---- Optional: subdomain prefix overrides ----
# Built-in services advertise these subdomains under ROOT_DOMAIN. The defaults
# match the documented URLs in INFRA.md / Cloudflare Tunnel setup. Override
# only if the default prefix collides with an existing record in your zone.
# Naming convention: *_HOST = subdomain prefix (joined with .${ROOT_DOMAIN});
# REGISTRY_HOST is the exception — see notes below.
# SEARCH_HOST=search          # → search.<ROOT_DOMAIN>     (Manticore HTTP UI)
# MQ_HOST=mq                  # → mq.<ROOT_DOMAIN>         (RabbitMQ mgmt UI)
# ARGOCD_HOST=argocd          # → argocd.<ROOT_DOMAIN>     (ArgoCD UI; full mode)
# HOOKS_HOST=hooks            # → hooks.<ROOT_DOMAIN>      (Tekton EventListener; full mode)
# REGISTRY_SUBDOMAIN=registry # → <prefix>.<ROOT_DOMAIN>   (only used when
#                             #   REGISTRY_PLUGIN=self-hosted; the aliyun-acr
#                             #   plugin sets REGISTRY_HOST to its own offsite
#                             #   value and ignores this prefix)

# ---- Optional: built-in upstream overrides ----
# Internal container:port that the built-in subdomains proxy to. Override only
# if you're swapping the implementation (e.g. external managed RabbitMQ).
# SEARCH_UPSTREAM=manticore:9308
# MQ_UPSTREAM=rabbitmq:15672

# ---- Cloudflare Tunnel ----
# Required for `full` mode only. Get from Cloudflare Dashboard → Zero Trust →
# Networks → Tunnels → Create.
CF_TUNNEL_TOKEN=

# ---- Platform plugins ----
# Registry plugin — see plugins/registry/<name>/ for available choices.
# Built-in: self-hosted (default), aliyun-acr
REGISTRY_PLUGIN=self-hosted

# Git provider plugin — Tekton EventListener triggers.
# Built-in: gitee (default), github, gitlab
GIT_PROVIDER_PLUGIN=gitee

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# ---- Redis ----
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# ---- Manticore Search ----
# Standalone mode has no built-in auth, so no key needed. The replication
# hook lives at core/compose/manticore/conf.d/ (see that dir's README.md).

# ---- Git provider credentials (full mode only) ----
# Used by ArgoCD to pull manifest repo and Tekton to clone app repos.
GIT_USER=
GIT_TOKEN=

# Webhook secret — Tekton EventListener verifies this against incoming hooks.
# Auto-generated if blank.
GIT_WEBHOOK_SECRET=

# Optional: restrict which repos may trigger builds. The webhook secret is
# shared across every onboarded repo, so a leak otherwise lets an attacker
# trigger kaniko builds + image pushes for any URL they post. Listing your
# repos here adds a CEL filter:
#   size(WHITELIST) == 0 || body.repository.git_http_url in WHITELIST
# Empty (default) = accept any repo.
WEBHOOK_REPO_WHITELIST=

# ---- Dashboard BasicAuth (full mode) ----
# Tekton Dashboard + Argo Rollouts UI both ship anonymous with WRITE access
# (cancel/delete PipelineRuns, abort/promote rollouts). Outpost wraps both in
# a shared Traefik BasicAuth middleware. User defaults to `outpost`; password
# is auto-generated if blank. For production, upgrade to Cloudflare Access.
OUTPOST_DASHBOARD_USER=outpost
OUTPOST_DASHBOARD_PASSWORD=

# ---- Manifest repository (ArgoCD source-of-truth, full mode only) ----
# HTTPS URL ending in .git
MANIFEST_REPO_URL=
MANIFEST_REPO_BRANCH=main

# ---- Deploy branch (CI/CD trigger) ----
# Branch of YOUR APP repo whose pushes trigger the CI/CD pipeline.
# Pushes to any other branch are ignored by the webhook. Default: main.
# Set to `master` (or your convention) for repos that don't use main.
# Distinct from MANIFEST_REPO_BRANCH above (the manifests repo ArgoCD watches).
OUTPOST_DEPLOY_BRANCH=main

# Auto-derived by bootstrap.sh from MANIFEST_REPO_URL (e.g. gitee.com /
# github.com / gitlab.com). Used by Tekton's git credentials Secret.
# Leave blank — bootstrap will populate it on first run.
GIT_HOST=

# ---- Aliyun ACR (only if REGISTRY_PLUGIN=aliyun-acr) ----
ALIYUN_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_ACR_NAMESPACE=
ALIYUN_ACR_USER=
ALIYUN_ACR_PASSWORD=

# =============================================================================
# CI/CD test gate + auto-rollback + notifications (full mode only)
# Proposal: i18n/{en,zh-CN}/docs/proposals/cicd-test-gate.md
# =============================================================================

# ---- Test runner plugin ----
# Built-in: testkube (default — K8s-native, 30+ engines), catalog-tasks (lightweight)
TEST_RUNNER=testkube
TESTKUBE_MODE=oss            # oss (default) | cloud
TESTKUBE_CLOUD_API_KEY=      # only if TESTKUBE_MODE=cloud (Phase 2)

# ---- Rollout plugin ----
# Built-in: argo-rollouts (default — canary + auto-rollback)
ROLLOUT_PLUGIN=argo-rollouts
ROLLOUTS_DASHBOARD_HOST=     # default: rollouts.${ROOT_DOMAIN}

# ---- Notification plugins ----
# Comma-separated list of enabled providers.
# Built-in: dingtalk, feishu, wecom, webhook-generic
# Empty disables CI/CD notifications entirely.
NOTIFICATION_PROVIDERS=

# DingTalk group robot
DINGTALK_WEBHOOK_URL=
DINGTALK_SIGN_SECRET=        # optional but recommended (HMAC-signed webhook)

# Feishu (Lark) custom bot
FEISHU_WEBHOOK_URL=
FEISHU_SIGN_SECRET=          # optional

# WeCom (企业微信) group robot
WECOM_WEBHOOK_URL=

# Generic webhook (POSTs raw normalized payload — for self-hosted relays)
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_BEARER=      # optional Bearer token
