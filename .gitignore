# Secrets — must never be committed
.env
.env.*
.env.local
*.local
INFRA.md
INFRA.zh-CN.md
sealed-secrets-key.pem
*.pem
*.key
secrets-backup/

# Local state
volumes/
.kubeconfig
kubeconfig

# Per-installation onboarded apps — content is generated by `outpost onboard`
# from each app's outpost.app.yaml; never commit the rendered fragments
# / compose overrides into the infras repo (the whole point of v0.5).
# Caddyfile.d/.gitkeep + Caddyfile.d/README.md are tracked exceptions.
core/compose/Caddyfile.d/*.caddy
core/compose/overrides/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
# Visual Studio / Rider auto-generated solution scaffold (we are not a .NET project)
*.sln
*.suo
*.user
.vs/

# Claude Code local workspace — PRP artifacts are tracked under docs/prp/
.claude/

# Logs
*.log
infra-autostart.log

# Test artifacts
tests/.coverage
tests/output/
.bats-tmp/
